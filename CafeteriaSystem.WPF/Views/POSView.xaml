<UserControl x:Class="CafeteriaSystem.WPF.Views.POSView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="2*" MinWidth="320"/>
        </Grid.ColumnDefinitions>

        <!-- ══════ LEFT: CATALOG ══════ -->
        <Grid Grid.Column="0" Background="{StaticResource BgSurfaceBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Search -->
            <Grid Grid.Row="0" Margin="20,16,20,0">
                <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18" VerticalAlignment="Center"
                                         Margin="12,0,0,0" Foreground="{StaticResource TextSecondaryBrush}" Panel.ZIndex="1"/>
                <TextBox Style="{StaticResource SearchBoxStyle}" Padding="40,10,12,10"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Buscar producto..."/>
            </Grid>

            <!-- Category Filters -->
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Hidden" Margin="16,12,16,0">
                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,0,8,0" Padding="14,7" Cursor="Hand"
                                    Command="{Binding DataContext.SelectCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource GhostButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentCoffeeBrush}"/>
                                                <Setter Property="Foreground" Value="#FF0F0E17"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"/>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Product Grid -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="12,16,12,16">
                <ItemsControl ItemsSource="{Binding DisplayedProducts}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource ProductCardStyle}" Width="160" Height="160">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.AddToCartCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <Border.Triggers>
                                    <EventTrigger RoutedEvent="MouseEnter">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                To="#FF2D2842" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                    <EventTrigger RoutedEvent="MouseLeave">
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                To="#FF241F36" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Border.Triggers>
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- Icon area -->
                                    <Border Background="#11E8A87C" CornerRadius="8" Margin="10,10,10,4" Height="80">
                                        <materialDesign:PackIcon Kind="FoodVariant" Width="40" Height="40"
                                                                 Foreground="{StaticResource AccentCoffeeBrush}"
                                                                 VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <!-- Info -->
                                    <StackPanel Grid.Row="1" Margin="10,0,10,10">
                                        <TextBlock Text="{Binding Name}" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" MaxHeight="32"/>
                                        <Grid Margin="0,4,0,0">
                                            <TextBlock Text="{Binding Price, StringFormat='RD${0:N0}'}"
                                                       FontSize="13" FontWeight="Bold" Foreground="{StaticResource AccentCoffeeBrush}"/>
                                            <Border HorizontalAlignment="Right" Visibility="{Binding HasLowStock, Converter={StaticResource BoolToVis}}">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource BadgeDangerStyle}">
                                                        <Setter Property="Padding" Value="4,1"/>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding CurrentStock}" FontSize="10"
                                                           Foreground="{StaticResource DangerBrush}"/>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- ══════ RIGHT: CART ══════ -->
        <Border Grid.Column="2" Background="{StaticResource SidebarBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Cart Header -->
                <Border Grid.Row="0" Padding="20,16" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush2}">
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CartOutline" Width="20" VerticalAlignment="Center" Foreground="{StaticResource AccentCoffeeBrush}"/>
                            <TextBlock Text="Mi Pedido" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            <Border Background="{StaticResource AccentCoffeeBrush}" CornerRadius="10" Margin="8,0,0,0" Padding="7,2">
                                <TextBlock Text="{Binding CartItemCount}" FontSize="11" FontWeight="Bold" Foreground="#FF0F0E17"/>
                            </Border>
                        </StackPanel>
                        <Button HorizontalAlignment="Right" Style="{StaticResource GhostButtonStyle}"
                                Command="{Binding ClearCartCommand}" Padding="8" ToolTip="Vaciar carrito">
                            <materialDesign:PackIcon Kind="DeleteOutline" Width="16" Foreground="{StaticResource DangerBrush}"/>
                        </Button>
                    </Grid>
                </Border>

                <!-- Cart Items -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding CartItems}" Margin="0,8">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="12,4" Padding="12" Background="{StaticResource BgElevatedBrush}" CornerRadius="8">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid>
                                            <TextBlock Text="{Binding ProductName}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" MaxWidth="160"/>
                                            <Button HorizontalAlignment="Right" Style="{StaticResource GhostButtonStyle}" Padding="4"
                                                    Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="Close" Width="12" Foreground="{StaticResource DangerBrush}"/>
                                            </Button>
                                        </Grid>
                                        <Grid Grid.Row="1" Margin="0,8,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <Button Style="{StaticResource GhostButtonStyle}" Padding="4"
                                                        Command="{Binding DataContext.DecreaseQtyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <materialDesign:PackIcon Kind="Minus" Width="12"/>
                                                </Button>
                                                <Border Background="{StaticResource BgCardBrush}" CornerRadius="4" Padding="10,4" Margin="4,0">
                                                    <TextBlock Text="{Binding Quantity}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                </Border>
                                                <Button Style="{StaticResource GhostButtonStyle}" Padding="4"
                                                        Command="{Binding DataContext.IncreaseQtyCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <materialDesign:PackIcon Kind="Plus" Width="12"/>
                                                </Button>
                                            </StackPanel>
                                            <TextBlock HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       Text="{Binding Total, StringFormat='RD${0:N2}'}"
                                                       FontWeight="Bold" FontSize="14" Foreground="{StaticResource AccentCoffeeBrush}"/>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Totals + Payment -->
                <Border Grid.Row="2" Padding="20" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush2}">
                    <StackPanel>
                        <!-- Subtotal / Tax / Discount / Total -->
                        <Grid Margin="0,0,0,4"><TextBlock Text="Subtotal" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                            <TextBlock HorizontalAlignment="Right" Text="{Binding Subtotal, StringFormat='RD${0:N2}'}" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>
                        <Grid Margin="0,0,0,4"><TextBlock Text="ITBIS (18%)" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                            <TextBlock HorizontalAlignment="Right" Text="{Binding TaxAmount, StringFormat='RD${0:N2}'}" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Grid>
                        <Grid Margin="0,0,0,4"><TextBlock Text="Descuento" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13"/>
                            <TextBlock HorizontalAlignment="Right" Text="{Binding DiscountAmount, StringFormat='-RD${0:N2}'}" Foreground="{StaticResource SuccessBrush}"/>
                        </Grid>
                        <Rectangle Height="1" Fill="{StaticResource BorderBrush2}" Margin="0,8"/>
                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="TOTAL" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock HorizontalAlignment="Right" Text="{Binding Total, StringFormat='RD${0:N2}'}"
                                       FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentCoffeeBrush}"/>
                        </Grid>

                        <!-- Monto Pagado -->
                        <TextBlock Text="Monto Recibido (RD$)" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                        <TextBox Style="{StaticResource SearchBoxStyle}" FontSize="16" FontWeight="SemiBold"
                                 Text="{Binding AmountPaid, UpdateSourceTrigger=PropertyChanged, StringFormat='N2'}" Margin="0,0,0,6"/>

                        <!-- Alerta: monto insuficiente -->
                        <Border Background="#33F44336" CornerRadius="6" Padding="10,7" Margin="0,0,0,8"
                                Visibility="{Binding InsufficientAmount, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AlertCircle" Foreground="{StaticResource DangerBrush}"
                                                         Width="16" VerticalAlignment="Center"/>
                                <TextBlock Margin="6,0,0,0" FontSize="12" Foreground="{StaticResource DangerBrush}"
                                           VerticalAlignment="Center">
                                    <Run Text="Monto insuficiente. Faltan:"/>
                                    <Run Text="{Binding Shortage, StringFormat='RD${0:N2}'}" FontWeight="Bold"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,0,0,12">
                            <TextBlock Text="Cambio:" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock HorizontalAlignment="Right" Text="{Binding Change, StringFormat='RD${0:N2}'}"
                                       FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                        </Grid>

                        <!-- Success banner -->
                        <Border Background="#334CAF50" CornerRadius="8" Padding="12,10" Margin="0,0,0,12"
                                Visibility="{Binding SaleSuccess, Converter={StaticResource BoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CheckCircle" Foreground="{StaticResource SuccessBrush}" Width="20" VerticalAlignment="Center"/>
                                <StackPanel Margin="8,0,0,0">
                                    <TextBlock Text="¡Venta procesada!" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}"/>
                                    <TextBlock Text="{Binding LastSaleNumber, StringFormat='Recibo: {0}'}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Cliente -->
                        <TextBlock Text="Nombre del Cliente" Style="{StaticResource LabelStyle}" Margin="0,0,0,4"/>
                        <Grid Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="Account" Width="16" Height="16"
                                                     VerticalAlignment="Center" Margin="10,0,0,0"
                                                     Foreground="{StaticResource TextSecondaryBrush}" Panel.ZIndex="1"/>
                            <TextBox Style="{StaticResource SearchBoxStyle}" Padding="34,8,12,8"
                                     Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"
                                     materialDesign:HintAssist.Hint="Consumidor Final (opcional)"/>
                        </Grid>

                        <!-- Cobrar Button -->
                        <Button Style="{StaticResource PrimaryButtonStyle}" Height="50" FontSize="16"
                                Command="{Binding ProcessSaleCommand}" IsEnabled="{Binding IsBusy, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CashRegister" Width="22" VerticalAlignment="Center"/>
                                <TextBlock Text="COBRAR" Margin="8,0,0,0" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
