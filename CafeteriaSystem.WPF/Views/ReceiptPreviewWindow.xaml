<Window x:Class="CafeteriaSystem.WPF.Views.ReceiptPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Vista Previa — Recibo" Height="620" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#FF131221" FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Recibo en pantalla -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="20,20,20,0">
            <Border Background="White" CornerRadius="4" Padding="24">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="2" Color="#000000" Opacity="0.15"/>
                </Border.Effect>
                <StackPanel x:Name="ReceiptPanel" TextElement.FontFamily="Courier New">

                    <!-- Header -->
                    <TextBlock x:Name="TxtBusiness" Text="CafeteriaSystem"
                               FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="#1A1A2E"/>
                    <TextBlock x:Name="TxtAddress" Text="Santo Domingo, RD"
                               FontSize="10" HorizontalAlignment="Center" Foreground="#888"/>
                    <TextBlock x:Name="TxtPhone" Text="Tel: (809) 000-0000"
                               FontSize="10" HorizontalAlignment="Center" Foreground="#888"/>

                    <Rectangle Height="1" Fill="#DDDDDD" Margin="0,10"/>

                    <!-- Datos de venta -->
                    <Grid Margin="0,0,0,2">
                        <TextBlock x:Name="TxtSaleNumber" FontSize="10" FontWeight="SemiBold" Foreground="#1A1A2E"/>
                        <TextBlock x:Name="TxtDate" HorizontalAlignment="Right" FontSize="10" Foreground="#888"/>
                    </Grid>
                    <Grid Margin="0,0,0,2">
                        <TextBlock x:Name="TxtCustomer" FontSize="10" Foreground="#1A1A2E"/>
                        <TextBlock x:Name="TxtCashier" HorizontalAlignment="Right" FontSize="10" Foreground="#888"/>
                    </Grid>

                    <Rectangle Height="1" Fill="#DDDDDD" Margin="0,8"/>

                    <!-- Encabezado tabla -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="PRODUCTO" FontSize="8" FontWeight="Bold" Foreground="#666"/>
                        <TextBlock Grid.Column="1" Text="CANT" FontSize="8" FontWeight="Bold"
                                   Foreground="#666" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="2" Text="P.UNIT" FontSize="8" FontWeight="Bold"
                                   Foreground="#666" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="3" Text="TOTAL" FontSize="8" FontWeight="Bold"
                                   Foreground="#666" HorizontalAlignment="Right"/>
                    </Grid>
                    <Rectangle Height="0.5" Fill="#DDDDDD" Margin="0,4"/>

                    <!-- Items -->
                    <ItemsControl x:Name="ItemsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding ProductName}" FontSize="9"
                                               Foreground="#222" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Quantity, StringFormat='F0'}"
                                               FontSize="9" Foreground="#222" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="{Binding UnitPrice, StringFormat='N2'}"
                                               FontSize="9" Foreground="#222" HorizontalAlignment="Right"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Total, StringFormat='N2'}"
                                               FontSize="9" Foreground="#222" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Rectangle Height="1" Fill="#DDDDDD" Margin="0,8"/>

                    <!-- Totales -->
                    <Grid Margin="0,2">
                        <TextBlock Text="Subtotal:" FontSize="10" Foreground="#333"/>
                        <TextBlock x:Name="TxtSubtotal" HorizontalAlignment="Right" FontSize="10" Foreground="#333"/>
                    </Grid>
                    <Grid x:Name="DiscountRow" Margin="0,2" Visibility="Collapsed">
                        <TextBlock Text="Descuento:" FontSize="10" Foreground="#4CAF50"/>
                        <TextBlock x:Name="TxtDiscount" HorizontalAlignment="Right" FontSize="10" Foreground="#4CAF50"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <TextBlock Text="ITBIS (18%):" FontSize="10" Foreground="#333"/>
                        <TextBlock x:Name="TxtTax" HorizontalAlignment="Right" FontSize="10" Foreground="#333"/>
                    </Grid>
                    <Rectangle Height="0.5" Fill="#DDDDDD" Margin="0,4"/>
                    <Grid Margin="0,2">
                        <TextBlock Text="TOTAL:" FontSize="13" FontWeight="Bold" Foreground="#1A1A2E"/>
                        <TextBlock x:Name="TxtTotal" HorizontalAlignment="Right"
                                   FontSize="13" FontWeight="Bold" Foreground="#1A1A2E"/>
                    </Grid>
                    <Rectangle Height="0.5" Fill="#DDDDDD" Margin="0,4"/>
                    <Grid Margin="0,2">
                        <TextBlock x:Name="TxtMethod" FontSize="10" Foreground="#888"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <TextBlock Text="Pagado:" FontSize="10" Foreground="#333"/>
                        <TextBlock x:Name="TxtPaid" HorizontalAlignment="Right" FontSize="10" Foreground="#333"/>
                    </Grid>
                    <Grid Margin="0,2">
                        <TextBlock Text="Cambio:" FontSize="10" Foreground="#333"/>
                        <TextBlock x:Name="TxtChange" HorizontalAlignment="Right" FontSize="10" Foreground="#333"/>
                    </Grid>

                    <Rectangle Height="1" Fill="#DDDDDD" Margin="0,10"/>

                    <!-- Footer -->
                    <TextBlock Text="¡Gracias por su compra!" FontWeight="Bold"
                               FontSize="10" HorizontalAlignment="Center" Foreground="#1A1A2E"/>
                    <TextBlock Text="Conserve su recibo" FontSize="8"
                               HorizontalAlignment="Center" Foreground="#AAA"/>
                </StackPanel>
            </Border>
        </ScrollViewer>

        <!-- Botones -->
        <Border Grid.Row="1" Background="#FF1C1A2B"
                BorderThickness="0,1,0,0" BorderBrush="#FF2D2B3D" Padding="20,14">
            <Grid>
                <Button HorizontalAlignment="Left" Click="BtnClose_Click" Padding="14,8"
                        Background="Transparent" BorderThickness="1" BorderBrush="#FF3D3B52"
                        Foreground="#FFB0AEC8" Cursor="Hand">
                    <TextBlock Text="Cerrar"/>
                </Button>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Padding="14,8" Margin="0,0,8,0" Click="BtnSavePdf_Click"
                            Background="Transparent" BorderThickness="1" BorderBrush="#FF3D3B52"
                            Foreground="#FFB0AEC8" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Download" Width="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Guardar PDF" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Padding="16,8" Click="BtnPrint_Click"
                            Background="#FFE8A87C" BorderThickness="0"
                            Foreground="#FF0F0E17" FontWeight="SemiBold" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Printer" Width="16" VerticalAlignment="Center"/>
                            <TextBlock Text="Imprimir" Margin="6,0,0,0" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
