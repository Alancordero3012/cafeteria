<Window x:Class="CafeteriaSystem.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:vm="clr-namespace:CafeteriaSystem.WPF.ViewModels"
        xmlns:views="clr-namespace:CafeteriaSystem.WPF.Views"
        Title="CafeteriaSystem — POS" Height="800" Width="1280"
        MinWidth="1100" MinHeight="650"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgSurfaceBrush}"
        FontFamily="Segoe UI">
    <Grid>
        <!-- ===== LOGIN STATE (full screen) ===== -->
        <ContentControl Content="{Binding LoginViewModel}"
                        Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"/>

        <!-- ===== MAIN APP STATE ===== -->
        <Grid Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ SIDEBAR ═══ -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Logo + App Name -->
                    <StackPanel Grid.Row="0" Margin="20,28,20,24">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="36" Height="36" CornerRadius="10" Background="{StaticResource AccentCoffeeBrush}">
                                <materialDesign:PackIcon Kind="Coffee" Width="22" Height="22" Foreground="#FF0F0E17" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="Cafetería" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Sistema POS" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Separador -->
                    <Rectangle Grid.Row="0" VerticalAlignment="Bottom" Height="1" Margin="16,0" Fill="{StaticResource BorderBrush2}"/>

                    <!-- Nav Items -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                        <StackPanel Margin="0,12">
                            <TextBlock Text="MENÚ PRINCIPAL" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="28,8,0,4"/>

                            <!-- Dashboard: visible para todos -->
                            <Button Style="{StaticResource NavButtonActiveStyle}"
                                    Command="{Binding NavigateToDashboardCommand}"
                                    Visibility="{Binding IsDashboardActive, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ViewDashboard" Width="18" VerticalAlignment="Center"/>
                                    <TextBlock Text="Dashboard" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavButtonStyle}"
                                    Command="{Binding NavigateToDashboardCommand}"
                                    Visibility="{Binding IsDashboardActive, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ViewDashboard" Width="18" VerticalAlignment="Center"/>
                                    <TextBlock Text="Dashboard" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- POS: visible para todos -->
                            <Button Style="{StaticResource NavButtonActiveStyle}"
                                    Command="{Binding NavigateToPOSCommand}"
                                    Visibility="{Binding IsPOSActive, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CashRegister" Width="18" VerticalAlignment="Center"/>
                                    <TextBlock Text="Punto de Venta" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource NavButtonStyle}"
                                    Command="{Binding NavigateToPOSCommand}"
                                    Visibility="{Binding IsPOSActive, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="CashRegister" Width="18" VerticalAlignment="Center"/>
                                    <TextBlock Text="Punto de Venta" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Inventario: CanManageProducts -->
                            <StackPanel Visibility="{Binding CurrentUser.CanManageProducts, Converter={StaticResource BoolToVis}}">
                                <Button Style="{StaticResource NavButtonActiveStyle}"
                                        Command="{Binding NavigateToInventoryCommand}"
                                        Visibility="{Binding IsInventoryActive, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="PackageVariant" Width="18" VerticalAlignment="Center"/>
                                        <TextBlock Text="Inventario" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource NavButtonStyle}"
                                        Command="{Binding NavigateToInventoryCommand}"
                                        Visibility="{Binding IsInventoryActive, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="PackageVariant" Width="18" VerticalAlignment="Center"/>
                                        <TextBlock Text="Inventario" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- Ventas: CanCancelSales (tiene acceso a historial de ventas) -->
                            <StackPanel Visibility="{Binding CurrentUser.CanCancelSales, Converter={StaticResource BoolToVis}}">
                                <Button Style="{StaticResource NavButtonActiveStyle}"
                                        Command="{Binding NavigateToSalesCommand}"
                                        Visibility="{Binding IsSalesActive, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="History" Width="18" VerticalAlignment="Center"/>
                                        <TextBlock Text="Ventas" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource NavButtonStyle}"
                                        Command="{Binding NavigateToSalesCommand}"
                                        Visibility="{Binding IsSalesActive, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="History" Width="18" VerticalAlignment="Center"/>
                                        <TextBlock Text="Ventas" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- Reportes: CanViewReports -->
                            <StackPanel Visibility="{Binding CurrentUser.CanViewReports, Converter={StaticResource BoolToVis}}">
                                <Button Style="{StaticResource NavButtonActiveStyle}"
                                        Command="{Binding NavigateToReportsCommand}"
                                        Visibility="{Binding IsReportsActive, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ChartBar" Width="18" VerticalAlignment="Center"/>
                                        <TextBlock Text="Reportes" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource NavButtonStyle}"
                                        Command="{Binding NavigateToReportsCommand}"
                                        Visibility="{Binding IsReportsActive, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ChartBar" Width="18" VerticalAlignment="Center"/>
                                        <TextBlock Text="Reportes" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- Productos: CanManageProducts -->
                            <StackPanel Visibility="{Binding CurrentUser.CanManageProducts, Converter={StaticResource BoolToVis}}">
                                <Button Style="{StaticResource NavButtonActiveStyle}"
                                        Command="{Binding NavigateToProductsCommand}"
                                        Visibility="{Binding IsProductsActive, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FoodVariant" Width="18" VerticalAlignment="Center"/>
                                        <TextBlock Text="Productos" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource NavButtonStyle}"
                                        Command="{Binding NavigateToProductsCommand}"
                                        Visibility="{Binding IsProductsActive, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="FoodVariant" Width="18" VerticalAlignment="Center"/>
                                        <TextBlock Text="Productos" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- Categorías: CanManageProducts -->
                            <StackPanel Visibility="{Binding CurrentUser.CanManageProducts, Converter={StaticResource BoolToVis}}">
                                <Button Style="{StaticResource NavButtonActiveStyle}"
                                        Command="{Binding NavigateToCategoriesCommand}"
                                        Visibility="{Binding IsCategoriesActive, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Tag" Width="18" VerticalAlignment="Center"/>
                                        <TextBlock Text="Categorías" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource NavButtonStyle}"
                                        Command="{Binding NavigateToCategoriesCommand}"
                                        Visibility="{Binding IsCategoriesActive, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Tag" Width="18" VerticalAlignment="Center"/>
                                        <TextBlock Text="Categorías" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- User Profile + Logout -->
                    <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush2}" Padding="16,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="18" Background="{Binding CurrentUser.AvatarColor}">
                                <TextBlock Text="{Binding CurrentUser.Initials}" Foreground="#FF0F0E17"
                                           FontWeight="Bold" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CurrentUser.FullName}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding CurrentUser.RoleName}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <Button Grid.Column="2" Style="{StaticResource GhostButtonStyle}"
                                    Command="{Binding LogoutCommand}" Padding="8" ToolTip="Cerrar Sesión">
                                <materialDesign:PackIcon Kind="Logout" Width="16" Height="16"/>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- ═══ CONTENT AREA ═══ -->
            <Grid Grid.Column="1" Background="{StaticResource BgSurfaceBrush}">
                <!-- Top bar / header -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource BgSurfaceBrush}"
                        BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrush2}" Padding="28,16">
                    <Grid>
                        <TextBlock Text="{Binding ActiveSection}" Style="{StaticResource SectionTitleStyle}" FontSize="20"/>
                        <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                            <TextBlock Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat='dddd, dd MMMM yyyy', Mode=OneTime}"
                                       xmlns:sys="clr-namespace:System;assembly=mscorlib"
                                       Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" FontSize="13"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- View Content -->
                <ContentControl Grid.Row="1" Content="{Binding CurrentViewModel}">
                    <ContentControl.Resources>
                        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
                            <views:DashboardView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:POSViewModel}">
                            <views:POSView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:InventoryViewModel}">
                            <views:InventoryView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:SalesHistoryViewModel}">
                            <views:SalesHistoryView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:ReportsViewModel}">
                            <views:ReportsView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:ProductsViewModel}">
                            <views:ProductsView/>
                        </DataTemplate>
                        <DataTemplate DataType="{x:Type vm:CategoriesViewModel}">
                            <views:CategoriesView/>
                        </DataTemplate>
                    </ContentControl.Resources>
                </ContentControl>
            </Grid>
        </Grid>
    </Grid>
</Window>
